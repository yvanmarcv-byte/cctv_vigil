# Flask Configuration
SECRET_KEY=change-me-to-a-random-string
FLASK_DEBUG=false

# Database (leave empty for SQLite, set for PostgreSQL)
DATABASE_URL=

# Admin Credentials (set before first run)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Network Devices (comma-separated IPs)
DEVICE_HOSTS=192.168.1.1,192.168.1.20,192.168.1.21

# Cloudinary (optional - for cloud video storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
